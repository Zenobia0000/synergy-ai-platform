# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/content_distributor

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# n8n
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=your-webhook-secret-here

# Auth (預留)
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# MinIO object storage
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=content-images
MINIO_SECURE=false

# Public base URL — set to your ngrok static domain so Instagram can fetch
# uploaded images via the tunnel. Example:
#   PUBLIC_BASE_URL=https://your-name-12345.ngrok-free.app
PUBLIC_BASE_URL=
