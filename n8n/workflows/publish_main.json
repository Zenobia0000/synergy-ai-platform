{
  "name": "Content Distributor - Publish Main",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "publish",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, message: 'Publishing triggered' }) }}"
      },
      "id": "respond-ok",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [450, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "check-ig",
              "leftValue": "={{ $json.body.platforms }}",
              "rightValue": "ig",
              "operator": {
                "type": "string",
                "operation": "contains"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "route-ig",
      "name": "Has IG Platform?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [650, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.instagram.com/v21.0/{{ $env.IG_USER_ID }}/media",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ image_url: $('Webhook Trigger').item.json.body.image_url, caption: $('Webhook Trigger').item.json.body.ig_caption || $('Webhook Trigger').item.json.body.master_caption, access_token: $env.IG_ACCESS_TOKEN }) }}",
        "options": {}
      },
      "id": "ig-create-container",
      "name": "IG Create Media Container",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [850, 200],
      "onError": "continueErrorOutput",
      "notes": "Step 1: Create media container. Reads IG_USER_ID and IG_ACCESS_TOKEN from n8n env (set via docker-compose)."
    },
    {
      "parameters": {
        "amount": 5,
        "unit": "seconds"
      },
      "id": "wait-ig-container",
      "name": "Wait for IG Container",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [950, 200],
      "notes": "Give Instagram a few seconds to fetch and process the image before calling media_publish (prevents code 9007 'Media ID is not available')."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.instagram.com/v21.0/{{ $env.IG_USER_ID }}/media_publish",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ creation_id: $json.id, access_token: $env.IG_ACCESS_TOKEN }) }}",
        "options": {}
      },
      "id": "ig-publish",
      "name": "IG Publish Media",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1050, 200],
      "onError": "continueErrorOutput",
      "notes": "Step 2: Publish the media container"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:8000/api/v1/webhooks/publish-result",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-N8N-Signature",
              "value": "={{ $env.N8N_WEBHOOK_SECRET }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ content_id: $('Webhook Trigger').item.json.body.content_id, platform: 'ig', status: 'success', external_post_id: $json.id || null, response_summary: 'Published to Instagram successfully' }) }}",
        "options": {}
      },
      "id": "report-ig-success",
      "name": "Report IG Success",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1250, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:8000/api/v1/webhooks/publish-result",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-N8N-Signature",
              "value": "={{ $env.N8N_WEBHOOK_SECRET }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ content_id: $('Webhook Trigger').item.json.body.content_id, platform: 'ig', status: 'failed', response_summary: ($json.error && $json.error.message) || $json.message || 'Instagram API error' }) }}",
        "options": {}
      },
      "id": "report-ig-failure",
      "name": "Report IG Failure",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1250, 450]
    }
  ],
  "connections": {
    "Webhook Trigger": {
      "main": [
        [
          { "node": "Respond OK", "type": "main", "index": 0 },
          { "node": "Has IG Platform?", "type": "main", "index": 0 }
        ]
      ]
    },
    "Has IG Platform?": {
      "main": [
        [{ "node": "IG Create Media Container", "type": "main", "index": 0 }],
        []
      ]
    },
    "IG Create Media Container": {
      "main": [
        [{ "node": "Wait for IG Container", "type": "main", "index": 0 }],
        [{ "node": "Report IG Failure", "type": "main", "index": 0 }]
      ]
    },
    "Wait for IG Container": {
      "main": [
        [{ "node": "IG Publish Media", "type": "main", "index": 0 }]
      ]
    },
    "IG Publish Media": {
      "main": [
        [{ "node": "Report IG Success", "type": "main", "index": 0 }],
        [{ "node": "Report IG Failure", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "instanceId": "local"
  },
  "tags": [
    { "name": "content-distributor" }
  ]
}
