# =====================================================
# Project root .env — used by docker-compose
# Copy to .env and fill in real values; .env is gitignored
# =====================================================

# Postgres (used by both postgres container and n8n container)
DB_PASSWORD=postgres

# n8n basic auth (login at http://localhost:5678)
N8N_USER=admin
N8N_PASSWORD=admin

# Webhook signature — MUST match backend/.env N8N_WEBHOOK_SECRET
# Generate with: openssl rand -hex 32
N8N_WEBHOOK_SECRET=replace-with-strong-random-hex

# =====================================================
# Instagram Graph API credentials
# How to obtain: see docs (Meta App + Page → IG Business linking)
# =====================================================

# Page Access Token (long-lived, ~60 days)
# Source: GET /me/accounts → access_token of the Page linked to your IG
IG_ACCESS_TOKEN=

# Instagram Business Account ID (17-digit number)
# Source: GET /<page-id>?fields=instagram_business_account
IG_USER_ID=

# =====================================================
# MinIO object storage (S3-compatible)
# =====================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=content-images
